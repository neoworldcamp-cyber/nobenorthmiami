---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "NoBe PARC Miami Beach | Luxury Residences from $560K",
  description = "Discover NoBe PARC, 222 fully furnished luxury residences at 7140 Abbott Ave, Miami Beach. Studios to 2-bedroom units from $560K. No rental restrictions. Beach service included.",
  image = "https://upload.wikimedia.org/wikipedia/commons/thumb/1/1c/Miami_Beach_SNU-MIA.jpg/1200px-Miami_Beach_SNU-MIA.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="NoBe PARC Miami Beach, luxury condos Miami Beach, Miami Beach real estate, furnished condos Miami, investment property Miami, Finvarb, Arquitectonica, North Beach Miami condos, residencias de lujo Miami Beach"
    />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="NoBe PARC Miami Beach" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WJNYB1LJ3Z"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-WJNYB1LJ3Z");
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="es_US" />
    <meta property="og:site_name" content="NoBe PARC Miami Beach" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />

    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "RealEstateListing",
        "name": "NoBe PARC Miami Beach",
        "description": "222 fully furnished luxury residences in Miami Beach. Studios to 2-bedroom units with no rental restrictions and beach service.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "7140 Abbott Ave",
          "addressLocality": "Miami Beach",
          "addressRegion": "FL",
          "addressCountry": "US"
        },
        "numberOfRooms": "222",
        "priceRange": "$560,000 - $1,300,000+",
        "url": "https://nobeparcmiami.com"
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg: #ffffff;
        --bg-warm: #f7f4f0;
        --bg-dark: #111111;
        --ink: #111111;
        --ink-mid: rgba(17, 17, 17, 0.72);
        --ink-faint: rgba(17, 17, 17, 0.14);
        --gold: #c4a882;
        --gold-light: #d9c4a8;
        --gold-dim: rgba(196, 168, 130, 0.15);
        --gold-border: rgba(196, 168, 130, 0.3);
        /* legacy aliases so existing component vars still resolve */
        --navy: #ffffff;
        --navy-mid: #f7f4f0;
        --navy-light: #eee9e2;
        --white: #111111;
        --white-dim: rgba(17, 17, 17, 0.72);
        --white-faint: rgba(17, 17, 17, 0.12);
        --charcoal: #111111;
        --light: #ffffff;
        --light-dim: rgba(255, 255, 255, 0.8);
        --light-faint: rgba(255, 255, 255, 0.15);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        font-size: 18px;
      }

      body {
        font-family: "DM Sans", sans-serif;
        background-color: var(--navy);
        color: var(--white);
        overflow-x: hidden;
        line-height: 1.75;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: "Cormorant Garamond", serif;
        font-weight: 300;
        line-height: 1.15;
      }

      /* ── Language toggle ── */
      html[data-lang="en"] .lang-es {
        display: none !important;
      }
      html[data-lang="es"] .lang-en {
        display: none !important;
      }

      .section-label {
        font-family: "DM Sans", sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
      }

      .gold-line {
        width: 48px;
        height: 1px;
        background: var(--gold);
        margin: 1.25rem 0;
      }

      .section-title {
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        color: var(--white);
        margin-bottom: 1.25rem;
      }

      .section-subtitle {
        font-size: 1.05rem;
        font-weight: 400;
        color: var(--white-dim);
        max-width: 560px;
        line-height: 1.85;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2.4rem;
        background: transparent;
        border: 1px solid var(--gold);
        color: var(--gold);
        font-family: "DM Sans", sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition:
          background 0.3s ease,
          color 0.3s ease;
      }

      .btn-primary:hover {
        background: var(--gold);
        color: var(--navy);
      }

      .btn-solid {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2.4rem;
        background: var(--gold);
        border: 1px solid var(--gold);
        color: var(--navy);
        font-family: "DM Sans", sans-serif;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition:
          background 0.3s ease,
          color 0.3s ease;
      }

      .btn-solid:hover {
        background: transparent;
        color: var(--gold);
      }

      /* WhatsApp icon inside buttons */
      .wa-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
      }

      ::selection {
        background: var(--gold);
        color: var(--navy);
      }

      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: var(--navy);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--gold-border);
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    <slot />

    <!-- WhatsApp Floating Button -->
    <a
      href="https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0"
      target="_blank"
      rel="noopener noreferrer"
      class="wa-float"
      id="waFloat"
      aria-label="Chat on WhatsApp"
    >
      <svg
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
        ></path>
        <path
          d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.123 1.532 5.855L.057 23.5l5.83-1.527A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.893 9.893 0 0 1-5.031-1.372l-.361-.214-3.741.98 1-3.634-.235-.374A9.869 9.869 0 0 1 2.106 12C2.106 6.533 6.533 2.106 12 2.106S21.894 6.533 21.894 12 17.467 21.894 12 21.894z"
        ></path>
      </svg>
      <span class="wa-float__tooltip lang-en">Chat on WhatsApp</span>
      <span class="wa-float__tooltip lang-es">Chatear por WhatsApp</span>
    </a>

    <style>
      .wa-float {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 900;
        width: 56px;
        height: 56px;
        background: #25d366;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
        text-decoration: none;
      }

      .wa-float:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 28px rgba(37, 211, 102, 0.6);
      }

      .wa-float svg {
        width: 28px;
        height: 28px;
        fill: #fff;
      }

      .wa-float__tooltip {
        position: absolute;
        right: 68px;
        background: rgba(17, 17, 17, 0.92);
        color: var(--white);
        font-family: "DM Sans", sans-serif;
        font-size: 0.68rem;
        font-weight: 500;
        white-space: nowrap;
        padding: 0.4rem 0.8rem;
        border: 1px solid var(--gold-border);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }

      .wa-float:hover .wa-float__tooltip {
        opacity: 1;
      }
    </style>

    <script>
      /* Language switcher — default ES, toggles data-lang on <html> */
      const html = document.documentElement;
      const stored = localStorage.getItem("nobe-lang");
      if (stored === "en") {
        html.setAttribute("data-lang", "en");
        html.setAttribute("lang", "en");
      }

      function toggleLang() {
        const current = html.getAttribute("data-lang") || "en";
        const next = current === "en" ? "es" : "en";
        html.setAttribute("data-lang", next);
        html.setAttribute("lang", next);
        localStorage.setItem("nobe-lang", next);

        // Update toggle button label
        document.querySelectorAll(".lang-toggle").forEach((btn) => {
          (btn as HTMLElement).setAttribute(
            "aria-label",
            next === "en" ? "Switch to Spanish" : "Switch to English",
          );
          const indicator = btn.querySelector(".lang-toggle__active");
          if (indicator) indicator.textContent = next.toUpperCase();
        });
      }

      document.querySelectorAll(".lang-toggle").forEach((btn) => {
        btn.addEventListener("click", toggleLang);
      });
    </script>
  </body>
</html>
