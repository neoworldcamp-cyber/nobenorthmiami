---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";
---
<section class="hero" id="hero" aria-label="NoBe PARC Miami Beach Hero">
  <div class="hero__video-wrap">
    <video
      class="hero__video"
      autoplay muted loop playsinline
      poster="https://upload.wikimedia.org/wikipedia/commons/thumb/1/1c/Miami_Beach_SNU-MIA.jpg/1920px-Miami_Beach_SNU-MIA.jpg"
      aria-hidden="true"
    >
      <!-- <source src="/videos/miami-aerial.mp4" type="video/mp4" /> -->
    </video>
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__content">
    <div class="hero__eyebrow">
      <span class="lang-en">Pre-Construction · Miami Beach · Est. Q3 2029</span>
      <span class="lang-es">Preventa · Miami Beach · Entrega Q3 2029</span>
    </div>

    <h1 class="hero__title">
      <span class="lang-en">Luxury Has Found<br/>Its <em>True North</em></span>
      <span class="lang-es">El Lujo Ha Encontrado<br/>Su <em>Verdadero Norte</em></span>
    </h1>

    <p class="hero__tagline">
      <span class="lang-en">7140 Abbott Ave, Miami Beach &nbsp;·&nbsp; From $560K &nbsp;·&nbsp; 222 Residences</span>
      <span class="lang-es">7140 Abbott Ave, Miami Beach &nbsp;·&nbsp; Desde $560K &nbsp;·&nbsp; 222 Residencias</span>
    </p>

    <div class="hero__actions">
      <a href={WA} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn--solid">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        <span class="lang-en">Contact on WhatsApp</span>
        <span class="lang-es">Contactar por WhatsApp</span>
      </a>
      <a href="#residences" class="hero-btn hero-btn--outline">
        <span class="lang-en">Explore Residences</span>
        <span class="lang-es">Ver Residencias</span>
      </a>
    </div>
  </div>

  <div class="hero__stats" role="region" aria-label="Key figures">
    <div class="stat">
      <strong>222</strong>
      <span class="lang-en">Residences</span>
      <span class="lang-es">Residencias</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <strong>14</strong>
      <span class="lang-en">Floors</span>
      <span class="lang-es">Pisos</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <strong><span class="lang-en">From $560K</span><span class="lang-es">Desde $560K</span></strong>
      <span class="lang-en">Starting Price</span>
      <span class="lang-es">Precio Inicial</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat">
      <strong><span class="lang-en">No Restrictions</span><span class="lang-es">Sin Restricciones</span></strong>
      <span class="lang-en">Rental Policy</span>
      <span class="lang-es">Política de Alquiler</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    /* At least one full visible viewport; can grow if content needs more space */
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Background image / video ── */
  .hero__video-wrap { position: absolute; inset: 0; z-index: 0; }

  .hero__video {
    width: 100%; height: 100%;
    object-fit: cover;
    background-image: url('https://upload.wikimedia.org/wikipedia/commons/thumb/1/1c/Miami_Beach_SNU-MIA.jpg/1920px-Miami_Beach_SNU-MIA.jpg');
    background-size: cover;
    background-position: center top;
  }

  /* ── Dark translucent scrim — keeps imagery visible, lifts text contrast ── */
  .hero__overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(to bottom,
        rgba(0,0,0,0.38) 0%,
        rgba(0,0,0,0.44) 28%,
        rgba(0,0,0,0.52) 48%,
        rgba(0,0,0,0.62) 68%,
        rgba(0,0,0,0.78) 100%
      );
  }

  /* ── Content ── */
  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: calc(env(safe-area-inset-top, 0px) + clamp(4.75rem, 11vh, 6.75rem)) 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: clamp(2rem, 6vh, 5rem);
    max-height: 100%;
  }

  /* Eyebrow label */
  .hero__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.30em;
    text-transform: uppercase;
    color: #C4A882;
    margin-bottom: 1.6rem;
  }

  /* Main title */
  .hero__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.35rem, 5.5vw, 4.75rem);
    font-weight: 300;
    color: #FFFFFF;
    line-height: 1.05;
    margin-bottom: 1.8rem;
    letter-spacing: -0.01em;
  }

  .hero__title em {
    font-style: italic;
    color: #C4A882;
  }

  /* Tagline */
  .hero__tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.80rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.75);
    text-transform: uppercase;
    margin-bottom: 3rem;
  }

  /* ── Hero-specific buttons (not the global btn-solid/btn-primary) ── */
  .hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.95rem 2.4rem;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.25s ease;
  }

  /* Solid — champagne gold fill */
  .hero-btn--solid {
    background: #C4A882;
    border: 1px solid #C4A882;
    color: #111111;
  }
  .hero-btn--solid:hover {
    background: transparent;
    border-color: #C4A882;
    color: #C4A882;
    transform: translateY(-1px);
  }

  /* Outline — white border */
  .hero-btn--outline {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.45);
    color: rgba(255,255,255,0.85);
  }
  .hero-btn--outline:hover {
    border-color: #C4A882;
    color: #C4A882;
    transform: translateY(-1px);
  }

  /* ── Stats bar — liquid glass dark ── */
  .hero__stats {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 8, 6, 0.55);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-top: 1px solid rgba(196, 168, 130, 0.20);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.4rem 3.5rem;
    gap: 0.3rem;
  }

  .stat strong {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: #C4A882;
    line-height: 1;
  }

  .stat span {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.70);
  }

  .stat-divider {
    width: 1px; height: 36px;
    background: rgba(196,168,130,0.20);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .stat { padding: 1rem 1.8rem; }
    .stat strong { font-size: 1.25rem; }
    .stat-divider { height: 24px; }
  }

  @media (max-width: 520px) {
    .hero__stats { flex-wrap: wrap; }
    .stat { width: 50%; padding: 0.9rem 0.5rem; }
    .stat-divider { display: none; }
    .hero__actions { flex-direction: column; align-items: center; }
    .hero-btn { width: 100%; justify-content: center; }
  }
</style>
