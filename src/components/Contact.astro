---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";
---
<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="contact__inner">
    <div class="contact__text">
      <p class="section-label">
        <span class="lang-en">Register Your Interest</span>
        <span class="lang-es">Registra tu Interés</span>
      </p>
      <div class="gold-line"></div>
      <h2 class="section-title" id="contact-heading">
        <span class="lang-en">Be the First to<br/>Secure Your Residence</span>
        <span class="lang-es">Sé el Primero en<br/>Asegurar tu Residencia</span>
      </h2>
      <p class="section-subtitle" style="margin-bottom:2.5rem;">
        <span class="lang-en">Pre-construction pricing is available for a limited time. Contact us on WhatsApp to receive exclusive floor plans, pricing details, and priority access before the public launch.</span>
        <span class="lang-es">El precio de preventa está disponible por tiempo limitado. Contáctanos por WhatsApp para recibir planos exclusivos, detalles de precios y acceso prioritario antes del lanzamiento público.</span>
      </p>

      <div class="contact__perks">
        <div class="perk">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><span class="lang-en">Exclusive floor plans & pricing</span><span class="lang-es">Planos exclusivos y precios</span></span>
        </div>
        <div class="perk">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><span class="lang-en">Priority unit selection</span><span class="lang-es">Selección prioritaria de unidad</span></span>
        </div>
        <div class="perk">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><span class="lang-en">Pre-construction pricing locked in</span><span class="lang-es">Precio de preventa bloqueado</span></span>
        </div>
        <div class="perk">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><span class="lang-en">No commitment required</span><span class="lang-es">Sin compromiso para registrarse</span></span>
        </div>
      </div>
    </div>

    <div class="contact__wa-card">
      <div class="wa-card__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
      </div>

      <h3 class="wa-card__title">
        <span class="lang-en">Talk to an expert<br/>right now</span>
        <span class="lang-es">Habla con un experto<br/>ahora mismo</span>
      </h3>

      <p class="wa-card__sub">
        <span class="lang-en">Our sales team is ready to answer all your questions about NoBe PARC — floor plans, prices, investment returns, and financing options.</span>
        <span class="lang-es">Nuestro equipo de ventas está listo para responder todas tus preguntas sobre NoBe PARC — planos, precios, retornos de inversión y opciones de financiamiento.</span>
      </p>

      <a href={WA} target="_blank" rel="noopener noreferrer" class="wa-card__btn">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        <span class="lang-en">Chat on WhatsApp</span>
        <span class="lang-es">Chatear por WhatsApp</span>
      </a>

      <p class="wa-card__hours">
        <span class="lang-en">Available Mon–Sat · 9am–7pm EST</span>
        <span class="lang-es">Disponible Lun–Sáb · 9am–7pm EST</span>
      </p>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 9rem 3rem;
    background: var(--navy-mid);
    border-top: 1px solid var(--gold-border);
  }

  .contact__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .contact__perks { display: flex; flex-direction: column; gap: 0.9rem; }

  .perk { display: flex; align-items: center; gap: 0.75rem; color: var(--gold); }

  .perk span { font-size: 0.95rem; color: var(--white-dim); }

  .contact__wa-card {
    background: var(--navy-light);
    border: 1px solid var(--gold-border);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .wa-card__icon {
    width: 72px; height: 72px;
    background: #25d366;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 32px rgba(37,211,102,.35);
  }

  .wa-card__icon svg { width: 36px; height: 36px; }

  .wa-card__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem; font-weight: 300;
    color: var(--white); line-height: 1.2;
  }

  .wa-card__sub { font-size: 0.98rem; color: var(--white-dim); line-height: 1.80; }

  .wa-card__btn {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: #25d366;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem; font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 2.2rem;
    width: 100%; justify-content: center;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .wa-card__btn svg { width: 20px; height: 20px; flex-shrink: 0; }

  .wa-card__btn:hover { background: #1ebe5d; transform: translateY(-2px); }

  .wa-card__hours { font-size: 0.76rem; color: rgba(17,17,17,.55); letter-spacing: 0.1em; }

  @media (max-width: 900px) {
    .contact__inner { grid-template-columns: 1fr; gap: 3.5rem; }
    .contact { padding: 5rem 1.5rem; }
  }
</style>
