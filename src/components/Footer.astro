---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";
---
<footer class="footer" role="contentinfo">
  <div class="footer__top">
    <div class="footer__brand">
      <div class="footer__logo">
        <span class="logo-nobe">NoBe</span>
        <span class="logo-parc">PARC</span>
        <span class="logo-location">Miami Beach</span>
      </div>
      <p class="footer__tagline">
        <span class="lang-en">222 luxury residences rising above<br/>the iconic North Shore of Miami Beach.</span>
        <span class="lang-es">222 residencias de lujo que se elevan sobre<br/>el icónico North Shore de Miami Beach.</span>
      </p>
      <address class="footer__address">
        7140 Abbott Ave<br />
        Miami Beach, FL 33141
      </address>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="footer__wa">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        +1 (786) 965-1217
      </a>
    </div>

    <div class="footer__links">
      <div class="footer__col">
        <h4><span class="lang-en">Navigate</span><span class="lang-es">Navegar</span></h4>
        <nav>
          <a href="#residences"><span class="lang-en">Residences</span><span class="lang-es">Residencias</span></a>
          <a href="#amenities"><span class="lang-en">Amenities</span><span class="lang-es">Amenidades</span></a>
          <a href="#location"><span class="lang-en">Location</span><span class="lang-es">Ubicación</span></a>
          <a href="#payment"><span class="lang-en">Investment</span><span class="lang-es">Inversión</span></a>
          <a href="#developers"><span class="lang-en">Developers</span><span class="lang-es">Desarrolladores</span></a>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">Contact</span><span class="lang-es">Contacto</span></a>
        </nav>
      </div>

      <div class="footer__col">
        <h4><span class="lang-en">Residences</span><span class="lang-es">Residencias</span></h4>
        <nav>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">Studios from $560K</span><span class="lang-es">Estudios desde $560K</span></a>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">1 Bedroom from $820K</span><span class="lang-es">1 Dormitorio desde $820K</span></a>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">1 + Den from $800K</span><span class="lang-es">1 + Den desde $800K</span></a>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">1 + Den + 2 Bath from $850K</span><span class="lang-es">1 + Den + 2 Baños desde $850K</span></a>
          <a href={WA} target="_blank" rel="noopener noreferrer"><span class="lang-en">2 Bedrooms from $1.3M</span><span class="lang-es">2 Dormitorios desde $1.3M</span></a>
        </nav>
      </div>

      <div class="footer__col">
        <h4><span class="lang-en">The Project</span><span class="lang-es">El Proyecto</span></h4>
        <nav>
          <a href="#about"><span class="lang-en">About NoBe PARC</span><span class="lang-es">Sobre NoBe PARC</span></a>
          <a href="#developers"><span class="lang-en">Developer: Finvarb</span><span class="lang-es">Desarrollador: Finvarb</span></a>
          <a href="#developers"><span class="lang-en">Architect: Arquitectonica</span><span class="lang-es">Arquitecto: Arquitectonica</span></a>
          <a href="#payment"><span class="lang-en">Payment Plan</span><span class="lang-es">Plan de Pagos</span></a>
        </nav>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {new Date().getFullYear()} NoBe PARC Miami Beach. <span class="lang-en">All rights reserved.</span><span class="lang-es">Todos los derechos reservados.</span></p>
    <p class="footer__disclaimer">
      <span class="lang-en">Renderings, floor plans, and specifications are for representational purposes only and are subject to change. This is not an offering where prohibited by law. Prices, availability, and terms are subject to change without notice.</span>
      <span class="lang-es">Los renders, planos y especificaciones son solo representativos y están sujetos a cambios. Esto no constituye una oferta donde esté prohibido por ley. Los precios, disponibilidad y condiciones pueden cambiar sin previo aviso.</span>
    </p>
  </div>
</footer>

<style>
  .footer { background: #111111; border-top: 1px solid rgba(196,168,130,0.20); padding: 5rem 3rem 2.5rem; }

  .footer__top { display: grid; grid-template-columns: 1.2fr 2fr; gap: 5rem; max-width: 1200px; margin: 0 auto; padding-bottom: 3.5rem; border-bottom: 1px solid var(--gold-border); margin-bottom: 2rem; }

  .footer__logo { display: flex; flex-direction: column; line-height: 1; gap: 0.1rem; margin-bottom: 1.5rem; }

  .logo-nobe { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 300; color: #FFFFFF; letter-spacing: 0.15em; }

  .logo-parc { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 600; color: var(--gold); letter-spacing: 0.15em; margin-top: -0.4rem; }

  .logo-location { font-family: 'DM Sans', sans-serif; font-size: 0.65rem; font-weight: 500; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,.55); margin-top: 0.2rem; }

  .footer__tagline { font-size: 0.96rem; color: rgba(255,255,255,.80); line-height: 1.80; margin-bottom: 1.2rem; }

  .footer__address { font-style: normal; font-size: 0.90rem; color: rgba(255,255,255,.55); line-height: 1.75; margin-bottom: 1.2rem; }

  .footer__wa {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-family: 'DM Sans', sans-serif; font-size: 0.90rem; font-weight: 500;
    color: #25d366; text-decoration: none;
    transition: opacity 0.25s;
  }

  .footer__wa:hover { opacity: 0.8; }

  .footer__wa svg { width: 16px; height: 16px; }

  .footer__links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

  .footer__col h4 { font-family: 'DM Sans', sans-serif; font-size: 0.6rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }

  .footer__col nav { display: flex; flex-direction: column; gap: 0.65rem; }

  .footer__col a { font-size: 0.90rem; color: rgba(255,255,255,.65); text-decoration: none; transition: color 0.25s; }

  .footer__col a:hover { color: var(--gold); }

  .footer__bottom { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.8rem; }

  .footer__bottom p { font-size: 0.82rem; color: rgba(255,255,255,.45); }

  .footer__disclaimer { font-size: 0.76rem !important; line-height: 1.65; max-width: 900px; }

  @media (max-width: 900px) { .footer__top { grid-template-columns: 1fr; gap: 3rem; } .footer { padding: 4rem 1.5rem 2rem; } }

  @media (max-width: 600px) { .footer__links { grid-template-columns: 1fr 1fr; } }
</style>
