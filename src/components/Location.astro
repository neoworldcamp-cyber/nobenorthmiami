---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";

const distEN = [
  { dist: "Steps", label: "to North Shore Beach" },
  { dist: "5 min", label: "to Bal Harbour Shops" },
  { dist: "10 min", label: "to South Beach" },
  { dist: "20 min", label: "to Miami International Airport" },
  { dist: "15 min", label: "to Wynwood Arts District" },
  { dist: "8 min", label: "to Surfside & Aventura" },
];

const distES = [
  { dist: "A pasos", label: "de North Shore Beach" },
  { dist: "5 min", label: "de Bal Harbour Shops" },
  { dist: "10 min", label: "de South Beach" },
  { dist: "20 min", label: "del Aeropuerto Internacional de Miami" },
  { dist: "15 min", label: "del Distrito de Arte Wynwood" },
  { dist: "8 min", label: "de Surfside & Aventura" },
];
---

<section class="location" id="location" aria-labelledby="location-heading">
  <div class="location__inner">
    <div class="location__header">
      <p class="section-label">
        <span class="lang-en">Prime Location</span>
        <span class="lang-es">Ubicación Privilegiada</span>
      </p>
      <div class="gold-line"></div>
      <h2 class="section-title" id="location-heading">
        7140 Abbott Ave<br/>
        <em>Miami Beach, FL</em>
      </h2>
      <p class="section-subtitle">
        <span class="lang-en">Positioned at the heart of North Beach — Miami's most exciting emerging neighborhood — NoBe PARC places you steps from the sand and moments from everything the Magic City offers.</span>
        <span class="lang-es">Ubicado en el corazón de North Beach — el barrio emergente más emocionante de Miami — NoBe PARC te pone a pasos de la arena y a minutos de todo lo que la Ciudad Mágica ofrece.</span>
      </p>
    </div>

    <!-- Distances EN -->
    <div class="location__distances lang-en">
      {distEN.map((h) => (
        <div class="distance-item">
          <span class="dist-value">{h.dist}</span>
          <span class="dist-label">{h.label}</span>
        </div>
      ))}
    </div>

    <!-- Distances ES -->
    <div class="location__distances lang-es">
      {distES.map((h) => (
        <div class="distance-item">
          <span class="dist-value">{h.dist}</span>
          <span class="dist-label">{h.label}</span>
        </div>
      ))}
    </div>

    <div class="location__bottom">
      <div class="location__address-card">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <address>7140 Abbott Ave, Miami Beach, FL 33141</address>
      </div>

      <div class="location__actions">
        <a
          href="https://maps.google.com/?q=7140+Abbott+Ave+Miami+Beach+FL"
          target="_blank" rel="noopener noreferrer"
          class="btn-primary"
        >
          <span class="lang-en">View on Map</span>
          <span class="lang-es">Ver en el Mapa</span>
        </a>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="btn-solid">
          <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          <span class="lang-en">Contact Us</span>
          <span class="lang-es">Contáctanos</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .location {
    padding: 8rem 3rem;
    background: var(--navy);
    border-top: 1px solid var(--gold-border);
  }

  .location__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    gap: 3.5rem;
  }

  .location__header { max-width: 620px; }

  .location__header h2 em { font-style: italic; color: var(--gold-light); }

  .location__distances {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--gold-border);
  }

  .distance-item {
    background: var(--navy-mid);
    padding: 1.5rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background 0.25s;
  }

  .distance-item:hover { background: var(--gold-dim); }

  .dist-value {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }

  .dist-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--white-dim);
  }

  .location__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--gold-border);
    flex-wrap: wrap;
  }

  .location__address-card {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--gold);
  }

  .location__address-card address {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    color: var(--white-dim);
  }

  .location__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .location__distances { grid-template-columns: repeat(2, 1fr); }
    .location { padding: 5rem 1.5rem; }
    .location__bottom { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .location__distances { grid-template-columns: 1fr 1fr; }
  }
</style>
