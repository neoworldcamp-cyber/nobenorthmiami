---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";
---
<section class="about" id="about" aria-labelledby="about-heading">
  <div class="about__inner">

    <div class="about__intro">
      <p class="section-label">
        <span class="lang-en">About the Project</span>
        <span class="lang-es">Sobre el Proyecto</span>
      </p>
      <div class="gold-line"></div>
      <h2 class="section-title" id="about-heading">
        <span class="lang-en">A New Era of<br/>North Beach Living</span>
        <span class="lang-es">Una Nueva Era del<br/>Lujo en North Beach</span>
      </h2>
      <p class="section-subtitle" style="margin-bottom:1.6rem;">
        <span class="lang-en">NoBe PARC redefines the Miami Beach skyline with 222 fully furnished residences rising 14 stories above the North Shore — where city energy meets oceanfront serenity.</span>
        <span class="lang-es">NoBe PARC redefine el horizonte de Miami Beach con 222 residencias completamente amobladas que se elevan 14 pisos sobre el North Shore — donde la energía urbana se encuentra con la serenidad del océano.</span>
      </p>
      <p class="section-subtitle">
        <span class="lang-en">Designed by the legendary firm <strong class="gold-text">Arquitectonica</strong> and developed by <strong class="gold-text">Finvarb</strong>, each residence arrives move-in ready, investment-ready, and curated to the last detail.</span>
        <span class="lang-es">Diseñado por la legendaria firma <strong class="gold-text">Arquitectonica</strong> y desarrollado por <strong class="gold-text">Finvarb</strong>, cada residencia llega lista para habitar, lista para invertir y curada hasta el último detalle.</span>
      </p>
    </div>

    <div class="about__stats">
      <div class="stat-card">
        <span class="stat-num">222</span>
        <span class="stat-label lang-en">Fully Furnished Residences</span>
        <span class="stat-label lang-es">Residencias Amobladas</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">14</span>
        <span class="stat-label lang-en">Floors</span>
        <span class="stat-label lang-es">Pisos</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">5</span>
        <span class="stat-label lang-en">Unit Types</span>
        <span class="stat-label lang-es">Tipos de Unidad</span>
      </div>
      <div class="stat-card stat-card--gold">
        <span class="stat-num">$560K</span>
        <span class="stat-label lang-en">Starting Price</span>
        <span class="stat-label lang-es">Precio Inicial</span>
      </div>
    </div>

    <div class="about__pillars">
      <div class="pillar">
        <div class="pillar__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div>
          <h3><span class="lang-en">Fully Furnished</span><span class="lang-es">Completamente Amoblado</span></h3>
          <p>
            <span class="lang-en">Every unit delivered turnkey — no extra investment required to start living or renting.</span>
            <span class="lang-es">Cada unidad entregada llave en mano — sin inversión adicional para comenzar a vivir o rentar.</span>
          </p>
        </div>
      </div>
      <div class="pillar">
        <div class="pillar__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <h3><span class="lang-en">No Rental Restrictions</span><span class="lang-es">Sin Restricciones de Alquiler</span></h3>
          <p>
            <span class="lang-en">Maximize your ROI with complete flexibility — short or long-term rentals permitted.</span>
            <span class="lang-es">Maximiza tu ROI con total flexibilidad — se permiten rentas cortas y largas.</span>
          </p>
        </div>
      </div>
      <div class="pillar">
        <div class="pillar__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <h3><span class="lang-en">Beach Service Included</span><span class="lang-es">Servicio de Playa Incluido</span></h3>
          <p>
            <span class="lang-en">Private beach amenities elevate the resort lifestyle — every day feels like a vacation.</span>
            <span class="lang-es">Las amenidades privadas de playa elevan el estilo de vida resort — cada día se siente como vacaciones.</span>
          </p>
        </div>
      </div>
    </div>

    <div class="about__cta">
      <a href={WA} target="_blank" rel="noopener noreferrer" class="btn-solid">
        <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        <span class="lang-en">Request Full Brochure</span>
        <span class="lang-es">Solicitar Brochure Completo</span>
      </a>
    </div>

  </div>
</section>

<style>
  .about {
    padding: 8rem 3rem;
    background: var(--navy-mid);
    border-top: 1px solid var(--gold-border);
  }

  .about__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    gap: 4rem;
  }

  .gold-text { color: var(--gold-light); font-weight: 500; }

  /* Stats row */
  .about__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5px;
    background: var(--gold-border);
  }

  .stat-card {
    background: var(--navy);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    transition: background 0.3s;
  }

  .stat-card:hover { background: var(--navy-light); }

  .stat-card--gold { background: var(--gold-dim); }

  .stat-card--gold:hover { background: rgba(201,160,68,.2); }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-dim);
  }

  /* Pillars */
  .about__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--gold-border);
  }

  .pillar {
    background: var(--navy);
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    padding: 2rem;
    transition: background 0.25s;
  }

  .pillar:hover { background: var(--navy-light); }

  .pillar__icon { color: var(--gold); margin-top: 0.2rem; flex-shrink: 0; }

  .pillar h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.4rem;
  }

  .pillar p { font-size: 0.92rem; color: var(--white-dim); line-height: 1.80; }

  .about__cta { display: flex; }

  @media (max-width: 900px) {
    .about__stats { grid-template-columns: repeat(2, 1fr); }
    .about__pillars { grid-template-columns: 1fr; }
    .about { padding: 5rem 1.5rem; }
  }

  @media (max-width: 500px) {
    .about__stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
