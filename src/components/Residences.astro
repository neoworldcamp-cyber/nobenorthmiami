---
const WA = "https://api.whatsapp.com/send/?phone=17869651217&text&type=phone_number&app_absent=0";

const unitsEN = [
  { type: "Studio & Jr. 1 Bed", price: "From $560K", badge: "Best Seller", desc: "Smartly designed for the cosmopolitan investor or first-time Miami Beach owner. Maximum efficiency, premium finishes." },
  { type: "1 Bedroom", price: "From $820K", badge: null, desc: "Open-plan living with resort-style interiors, floor-to-ceiling windows, and turnkey furnishings that command top rental rates." },
  { type: "1 Bed + Den", price: "From $800K", badge: null, desc: "Versatile den space adapts as a home office, guest room, or media lounge — the flexibility modern buyers demand." },
  { type: "1 Bed + Den + 2 Bath", price: "From $850K", badge: null, desc: "Two full bathrooms elevate this unit's appeal for families and short-term rental guests seeking premium comfort." },
  { type: "2 Bedroom", price: "From $1.3M", badge: "Premium", desc: "Expansive two-bedroom residences offer the pinnacle of NoBe PARC living — generous space, stunning views, unrivaled luxury." },
];

const unitsES = [
  { type: "Estudio & Jr. 1 Hab.", price: "Desde $560K", badge: "Más Vendido", desc: "Diseñado inteligentemente para el inversor cosmopolita o el primer comprador en Miami Beach. Máxima eficiencia, acabados premium." },
  { type: "1 Dormitorio", price: "Desde $820K", badge: null, desc: "Espacios abiertos con interiores estilo resort, ventanas de piso a techo y mobiliario llave en mano que generan las mejores rentas." },
  { type: "1 Dorm. + Den", price: "Desde $800K", badge: null, desc: "El espacio den versátil se adapta como oficina, cuarto de huéspedes o sala multimedia — la flexibilidad que los compradores modernos exigen." },
  { type: "1 Dorm. + Den + 2 Baños", price: "Desde $850K", badge: null, desc: "Dos baños completos elevan el atractivo de esta unidad para familias y huéspedes de renta corta que buscan el máximo confort." },
  { type: "2 Dormitorios", price: "Desde $1.3M", badge: "Premium", desc: "Amplias residencias de dos dormitorios que ofrecen el pináculo del living en NoBe PARC — espacio generoso, vistas impresionantes, lujo sin rival." },
];
---

<section class="residences" id="residences" aria-labelledby="residences-heading">
  <div class="residences__inner">
    <div class="residences__header">
      <p class="section-label">
        <span class="lang-en">Residences</span>
        <span class="lang-es">Residencias</span>
      </p>
      <div class="gold-line" style="margin-left:auto;margin-right:auto;"></div>
      <h2 class="section-title" id="residences-heading">
        <span class="lang-en">Five Residences,<br/>One Standard of Excellence</span>
        <span class="lang-es">Cinco Residencias,<br/>Un Solo Estándar de Excelencia</span>
      </h2>
      <p class="section-subtitle" style="margin:0 auto;text-align:center;">
        <span class="lang-en">222 fully furnished residences across 14 floors — every unit delivered move-in ready with curated interiors, premium appliances, and resort-level finishes.</span>
        <span class="lang-es">222 residencias completamente amobladas en 14 pisos — cada unidad entregada lista para habitar con interiores seleccionados, electrodomésticos premium y acabados de nivel resort.</span>
      </p>
    </div>

    <!-- English grid -->
    <div class="residences__grid lang-en">
      {unitsEN.map((unit) => (
        <a href={WA} target="_blank" rel="noopener noreferrer" class="unit-card" aria-label={`Learn more about ${unit.type}`}>
          {unit.badge && <div class="unit-badge">{unit.badge}</div>}
          <div class="unit-card__body">
            <p class="unit-type">{unit.type}</p>
            <p class="unit-price">{unit.price}</p>
            <div class="unit-divider" aria-hidden="true"></div>
            <p class="unit-desc">{unit.desc}</p>
            <span class="unit-link">
              Request Info
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Spanish grid -->
    <div class="residences__grid lang-es">
      {unitsES.map((unit) => (
        <a href={WA} target="_blank" rel="noopener noreferrer" class="unit-card" aria-label={`Más info sobre ${unit.type}`}>
          {unit.badge && <div class="unit-badge">{unit.badge}</div>}
          <div class="unit-card__body">
            <p class="unit-type">{unit.type}</p>
            <p class="unit-price">{unit.price}</p>
            <div class="unit-divider" aria-hidden="true"></div>
            <p class="unit-desc">{unit.desc}</p>
            <span class="unit-link">
              Pedir Información
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="residences__cta">
      <p class="section-label" style="text-align:center;">
        <span class="lang-en">Limited Units Available</span>
        <span class="lang-es">Unidades Limitadas Disponibles</span>
      </p>
      <p class="cta-sub">
        <span class="lang-en">Secure your pre-construction price before they're gone</span>
        <span class="lang-es">Asegura tu precio de preventa antes de que se agoten</span>
      </p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="btn-solid">
        <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        <span class="lang-en">Reserve Your Unit</span>
        <span class="lang-es">Reservar tu Unidad</span>
      </a>
    </div>
  </div>
</section>

<style>
  .residences {
    padding: 8rem 3rem;
    background: var(--navy);
    border-top: 1px solid var(--gold-border);
    border-bottom: 1px solid var(--gold-border);
  }

  .residences__inner { max-width: 1200px; margin: 0 auto; }

  .residences__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
  }

  .residences__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5px;
    background: var(--gold-border);
    margin-bottom: 5rem;
  }

  .unit-card {
    position: relative;
    background: var(--navy-mid);
    text-decoration: none;
    display: block;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .unit-card:hover {
    background: var(--navy-light);
    transform: translateY(-3px);
    z-index: 2;
    box-shadow: 0 16px 48px rgba(0,0,0,.4);
  }

  .unit-badge {
    position: absolute;
    top: 0; left: 0; right: 0;
    background: var(--gold);
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.3rem;
    text-align: center;
  }

  .unit-card__body {
    padding: 2.2rem 1.6rem 2rem;
    padding-top: 2.8rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    min-height: 280px;
  }

  .unit-type {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }

  .unit-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.9rem;
    font-weight: 300;
    color: var(--white);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .unit-divider {
    width: 32px;
    height: 1px;
    background: var(--gold-border);
    margin-bottom: 1rem;
  }

  .unit-desc {
    font-size: 0.92rem;
    color: var(--white-dim);
    line-height: 1.75;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .unit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    transition: gap 0.25s;
    margin-top: auto;
  }

  .unit-card:hover .unit-link { gap: 0.8rem; }

  .residences__cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--white);
    margin: 0.8rem 0 2rem;
    font-weight: 300;
  }

  @media (max-width: 1100px) {
    .residences__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 700px) {
    .residences { padding: 5rem 1.5rem; }
    .residences__grid { grid-template-columns: repeat(2, 1fr); }
    .unit-card__body { min-height: unset; }
  }

  @media (max-width: 480px) {
    .residences__grid { grid-template-columns: 1fr; }
  }
</style>
